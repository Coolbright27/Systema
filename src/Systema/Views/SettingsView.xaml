<UserControl x:Class="Systema.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters"
             Background="{StaticResource BgPrimaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="GlobalBoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: page header -->
                <RowDefinition Height="28"/>    <!-- 1: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 2: System Restore card -->
                <RowDefinition Height="16"/>    <!-- 3: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 4: Manage Restore Points card -->
                <RowDefinition Height="16"/>    <!-- 5: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 6: Startup card -->
                <RowDefinition Height="16"/>    <!-- 7: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 8: Export/Import card -->
                <RowDefinition Height="16"/>    <!-- 9: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 10: bottom note -->
                <RowDefinition Height="20"/>    <!-- 11: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 12: Diagnostic Report card -->
                <RowDefinition Height="16"/>    <!-- 13: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 14: Updates card -->
                <RowDefinition Height="20"/>    <!-- 15: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 16: version footer -->
            </Grid.RowDefinitions>

            <!-- Page header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="Configure how Systema behaves, manage safety options, and run diagnostics."
                           Style="{StaticResource CaptionText}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ── System Restore ──────────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="System Restore" Style="{StaticResource HeadingMedium}" Margin="0,0,0,4"/>
                    <TextBlock Text="Systema creates a Windows restore point before making changes, so you can undo everything if something goes wrong."
                               Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Skip safety restore point" Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="When enabled, Systema will apply tweaks without creating a restore point first."
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,16,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding SkipRestorePoint}"
                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Margin="0,14,0,0" Padding="12,8" Background="#1AFF4560" CornerRadius="6"
                            Visibility="{Binding SkipRestorePoint, Converter={StaticResource GlobalBoolToVis}}">
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource AccentRedBrush}">
                            ⚠  Restore points are turned off. If something goes wrong after applying tweaks, you won't be able to roll back automatically.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Manage Restore Points ───────────────────────────────────────── -->
            <Border Grid.Row="4" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Restore Point Manager" Style="{StaticResource HeadingMedium}"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                            View, create, and delete Windows restore points. If something goes wrong
                            after making changes, use "Restore My PC" to roll your settings back to
                            an earlier date.
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Manage Restore Points"
                            VerticalAlignment="Center" Padding="18,10"
                            Command="{Binding ManageRestorePointsCommand}"
                            Style="{StaticResource GhostButton}"/>
                </Grid>
            </Border>

            <!-- ── Startup ──────────────────────────────────────────────────────── -->
            <Border Grid.Row="6" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Startup" Style="{StaticResource HeadingMedium}" Margin="0,0,0,4"/>
                    <TextBlock Text="Control whether Systema launches automatically when you sign in to Windows."
                               Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Launch on Windows startup" Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="Systema will start automatically when you sign in. Task Sleep waits ~45 seconds after boot so normal startup processes aren't affected."
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,16,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding StartWithWindows}"
                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,16,0,16" Background="{StaticResource BorderBrush}" Height="1" Opacity="0.3"/>

                    <!-- Keep Systema Running -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Keep Systema Running" Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,16,0">
                                Registers a Windows Task Scheduler watchdog that checks every 5 minutes and
                                restarts Systema automatically if it ever stops — even after a crash or accidental close.
                            </TextBlock>
                            <!-- Status feedback -->
                            <TextBlock Text="{Binding KeepRunningStatus}"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,4,16,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KeepRunningStatus}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding KeepSystemaRunning}"
                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Export / Import Settings ───────────────────────────────── -->
            <Border Grid.Row="8" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Export / Import Settings" Style="{StaticResource HeadingMedium}"/>
                        <Border Background="{StaticResource AccentBlueBrush}" CornerRadius="4"
                                Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BACKUP" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                        </Border>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                        Back up your Systema configuration to a JSON file, or restore it on a new machine.
                        This saves preferences like game boost settings, service kill list, and startup options.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Export Settings"
                                Padding="18,9" Margin="0,0,10,0"
                                Command="{Binding ExportSettingsCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Content="Import Settings"
                                Padding="18,9"
                                Command="{Binding ImportSettingsCommand}"
                                Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                    <!-- Status feedback — visible only when non-empty -->
                    <TextBlock Text="{Binding ExportImportStatus}"
                               Foreground="{StaticResource AccentGreenBrush}"
                               TextWrapping="Wrap" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ExportImportStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Bottom note -->
            <TextBlock Grid.Row="10"
                       Text="Settings are saved automatically to the Windows Registry under HKCU\Software\Systema."
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- ── Diagnostic Report ───────────────────────────────────────── -->
            <Border Grid.Row="12" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Diagnostic Report" Style="{StaticResource HeadingMedium}"/>
                            <Border Background="{StaticResource AccentBlueBrush}" CornerRadius="4"
                                    Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="DIAGNOSTIC" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                            </Border>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                            Creates a report of recent errors and session activity that you can paste into Discord for support. Nothing is sent automatically.
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1" Content="📋  Copy Diagnostic Report"
                            VerticalAlignment="Center" Padding="18,10"
                            Command="{Binding OpenDiagnosticsCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </Grid>
            </Border>

            <!-- ── Updates ─────────────────────────────────────────────────────── -->
            <Border Grid.Row="14" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Updates" Style="{StaticResource HeadingMedium}"/>
                        <!-- Badge — only visible when update is available -->
                        <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                Background="#1A4ADE80">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="UPDATE AVAILABLE" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Border>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,14">
                        Systema checks for updates every 2 hours and installs silently when your
                        CPU is idle. Updates are paused automatically during game sessions and
                        when CPU usage is high. No prompts, no interruptions.
                    </TextBlock>

                    <!-- Auto-update toggle -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Automatic updates" Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,2,16,0">
                                When on, Systema updates itself silently every 2 hours — paused during
                                game mode or when CPU usage is high. Manual checks always work regardless.
                            </TextBlock>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoUpdateEnabled}"
                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,0,0,14" Background="#22FFFFFF" Height="1"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Version + status text -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold">
                                <Run Text="Current version: "/>
                                <Run Text="{Binding CurrentVersionString, Mode=OneTime}"
                                     Foreground="{StaticResource AccentBlueBrush}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding UpdateStatus}" Margin="0,3,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Download progress bar — shown while downloading -->
                            <Grid Margin="0,8,16,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                             Height="4" Background="#22FFFFFF"
                                             Foreground="{StaticResource AccentBlueBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Right-side buttons — contextual based on state -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="12,0,0,0">

                            <!-- "Install Now" — only when installer is downloaded and ready -->
                            <Button Content="⬆  Install Now"
                                    Padding="18,9" Margin="0,0,8,0"
                                    Command="{Binding InstallNowCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReadyToInstall}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- "Check Now" — always available unless actively checking/downloading -->
                            <Button Content="Check Now"
                                    Padding="18,9"
                                    IsEnabled="{Binding CanCheckNow}"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Version footer -->
            <TextBlock Grid.Row="16"
                       Text="Systema v1.6.18  ·  For support visit discord.gg/DjxBswDeN8"
                       Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </Grid>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="Systema.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Memory &amp; Startup" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="See how much memory your PC is using and manage programs that run at startup."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- RAM Stats + Pagefile -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Quick Free RAM Card -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Quick Free RAM" Style="{StaticResource HeadingMedium}" Margin="0,0,0,6"/>

                        <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,10">
                            Forces every background process to release memory it's holding but not actively
                            using, then purges Windows' standby list. Useful when RAM is running low or
                            before starting a memory-heavy task.
                        </TextBlock>

                        <!-- Live free RAM stat -->
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,12">
                            <Run Text="{Binding AvailableRamMb, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                            <Run Text=" MB free  ·  "/>
                            <Run Text="{Binding TotalRamMb, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                            <Run Text=" MB total"/>
                        </TextBlock>

                        <!-- Free RAM button — label + enabled state driven by IsFreeing -->
                        <Button Command="{Binding FreeRamCommand}" HorizontalAlignment="Left">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content"    Value="Free RAM Now"/>
                                    <Setter Property="IsEnabled"  Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFreeing}" Value="True">
                                            <Setter Property="Content"   Value="Flushing…"/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Status / result text -->
                        <TextBlock Text="{Binding FreeRamStatus}"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FreeRamStatus}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Pagefile Card — disabled/grayed on HDD -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Virtual Memory (Pagefile)" Style="{StaticResource HeadingMedium}"/>
                            <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="4"
                                    Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="MODERATE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,4">
                            Windows uses a hidden file on your drive as extra memory when RAM fills up.
                            Locking the size prevents performance hiccups.
                            Most users can leave this on the default setting. A restart is required to apply.
                        </TextBlock>
                        <TextBlock Text="{Binding CurrentPagefileText}"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding RecommendedPagefileText}"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Initial Size (MB)" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PagefileInitialMb, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Maximum Size (MB)" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PagefileMaxMb, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Apply Changes"
                                    Command="{Binding ConfigurePagefileCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Reset to Default"
                                    Command="{Binding RevertPagefileCommand}"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Startup Manager Header -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="Startup Programs" Style="{StaticResource HeadingMedium}"/>
                <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="{Binding StartupItems.Count, Mode=OneWay}"/>
                    <Run Text=" programs start automatically with Windows. Disabling ones you don't need speeds up boot time."/>
                    <Run Text=" The Impact column shows roughly how much each one slows down your startup."/>
                </TextBlock>
            </StackPanel>

            <!-- Startup List -->
            <Border Grid.Row="6" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,10" CornerRadius="10,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>   <!-- IMPACT -->
                                <ColumnDefinition Width="110"/>  <!-- STATUS -->
                                <ColumnDefinition Width="80"/>   <!-- ACTION -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="NAME" Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="IMPACT" Style="{StaticResource CaptionText}"
                                       Grid.Column="1" HorizontalAlignment="Center"
                                       ToolTip="How much this program slows down your PC startup"/>
                            <TextBlock Text="STATUS" Style="{StaticResource CaptionText}"
                                       Grid.Column="2" HorizontalAlignment="Center"/>
                            <TextBlock Text="ACTION" Style="{StaticResource CaptionText}"
                                       Grid.Column="3" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Rows — scrollable; no MaxHeight so every item is reachable -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  MaxHeight="520" CanContentScroll="False">
                    <ItemsControl ItemsSource="{Binding StartupItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,8" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Name + command path (tooltip) -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                    ToolTip="{Binding Command}">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}"/>
                                            <TextBlock Text="{Binding Command}"
                                                       Style="{StaticResource CaptionText}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="320"
                                                       Opacity="0.6"/>
                                        </StackPanel>

                                        <!-- Impact badge -->
                                        <Border Grid.Column="1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" CornerRadius="4" Padding="7,3">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#141F2B45"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ImpactLabel}" Value="High">
                                                            <Setter Property="Background" Value="#22FF4560"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ImpactLabel}" Value="Medium">
                                                            <Setter Property="Background" Value="#22FFB800"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ImpactLabel}" Value="Low">
                                                            <Setter Property="Background" Value="#2200E5A0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding ImpactLabel}" FontSize="10"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImpactLabel}" Value="High">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ImpactLabel}" Value="Medium">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ImpactLabel}" Value="Low">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Status badge -->
                                        <Border Grid.Column="2" HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Text" Value="Enabled"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Text" Value="Disabled"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Enable / Disable toggle button -->
                                        <Button Grid.Column="3" Style="{StaticResource GhostButton}"
                                                Padding="8,4" HorizontalAlignment="Center"
                                                Command="{Binding DataContext.ToggleStartupItemCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Text" Value="Disable"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Text" Value="Enable"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Status + Refresh -->
            <Grid Grid.Row="7" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostButton}"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

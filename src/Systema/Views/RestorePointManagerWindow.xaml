<Window x:Class="Systema.Views.RestorePointManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Restore Points — Systema"
        Height="540" Width="780"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: header -->
            <RowDefinition Height="16"/>    <!-- 1: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 2: create new button row -->
            <RowDefinition Height="12"/>    <!-- 3: spacer -->
            <RowDefinition Height="*"/>     <!-- 4: list -->
            <RowDefinition Height="12"/>    <!-- 5: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 6: status -->
            <RowDefinition Height="16"/>    <!-- 7: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 8: bottom buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Manage Restore Points" Style="{StaticResource HeadingLarge}"/>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionText}" Margin="0,4,0,0">
                Restore points are safety snapshots of your Windows settings. If something goes wrong
                after making changes, you can go back to an earlier state. Click "Restore My PC" to
                open the Windows recovery wizard.
            </TextBlock>
        </StackPanel>

        <!-- Create / Refresh row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="CreateBtn" Content="➕  Create New Restore Point"
                    Style="{StaticResource PrimaryButton}" Padding="18,9" Margin="0,0,10,0"
                    Click="CreateBtn_Click"/>
            <Button x:Name="RefreshBtn" Content="↻  Refresh List"
                    Style="{StaticResource GhostButton}" Padding="14,9"
                    Click="RefreshBtn_Click"/>
        </StackPanel>

        <!-- Restore point list -->
        <Border Grid.Row="4" Background="{StaticResource BgCardBrush}"
                CornerRadius="10" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- column headers -->
                    <RowDefinition Height="*"/>     <!-- rows -->
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10" CornerRadius="10,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DATE" Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="DESCRIPTION" Style="{StaticResource CaptionText}" Grid.Column="1"/>
                        <TextBlock Text="TYPE" Style="{StaticResource CaptionText}" Grid.Column="2"/>
                        <TextBlock Text="ACTION" Style="{StaticResource CaptionText}" Grid.Column="3" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Loading indicator -->
                        <TextBlock x:Name="LoadingText" Text="Loading restore points…"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center" Margin="0,20"/>

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyText" Text="No restore points found on this PC."
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center" Margin="0,20"
                                   Visibility="Collapsed"/>

                        <!-- Restore point rows (populated in code-behind) -->
                        <ItemsControl x:Name="PointsList" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,10" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding FormattedDate}"
                                                       Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                       Style="{StaticResource BodyText}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TypeLabel}"
                                                       Style="{StaticResource CaptionText}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="Delete"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="10,5" HorizontalAlignment="Center"
                                                    FontSize="11"
                                                    Tag="{Binding SequenceNumber}"
                                                    Click="DeleteBtn_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status message -->
        <TextBlock x:Name="StatusText" Grid.Row="6"
                   Style="{StaticResource CaptionText}" TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Bottom buttons -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔄  Restore My PC (opens Windows wizard)"
                    Style="{StaticResource GhostButton}" Padding="18,9"
                    HorizontalAlignment="Left"
                    Click="RestoreWizardBtn_Click"
                    ToolTip="Opens the Windows System Restore wizard so you can revert to an earlier state."/>

            <Button Grid.Column="1" Content="Close"
                    Style="{StaticResource GhostButton}" Padding="18,9"
                    Click="CloseBtn_Click"/>
        </Grid>
    </Grid>
</Window>

<UserControl x:Class="Systema.Views.GameBoosterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters"
             Background="{StaticResource BgPrimaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Transparent, borderless clickable button used for section expanders -->
        <Style x:Key="ExpanderButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="0">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0CFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: header -->
                <RowDefinition Height="20"/>    <!-- 1: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 2: Boost Status card -->
                <RowDefinition Height="16"/>    <!-- 3: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 4: Manual Boost card -->
                <RowDefinition Height="20"/>    <!-- 5: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 6: Booster Settings card -->
                <RowDefinition Height="20"/>    <!-- 7: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 8: Boost Actions card -->
                <RowDefinition Height="20"/>    <!-- 9: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 10: Detection Info card -->
                <RowDefinition Height="Auto"/>  <!-- 11: status bar -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Game Booster" Style="{StaticResource HeadingLarge}"/>
                    <TextBlock Text="Auto-detects games and suspends non-essential services while you play."
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Master enable/disable toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disabled"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameBoosterEnabled}" Value="True">
                                        <Setter Property="Text" Value="Enabled"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <CheckBox Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding GameBoosterEnabled}" VerticalAlignment="Center"
                              ToolTip="Master switch — turn off to disable all game detection and boosting"/>
                </StackPanel>
            </Grid>

            <!-- ── Boost Status Card ─────────────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <!-- Active indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="14" Height="14" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BoostActive}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource HeadingMedium}">
                                        <Setter Property="Text" Value="Game Boost Idle"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BoostActive}" Value="True">
                                                <Setter Property="Text" Value="Game Boosting Active!"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Active Game: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="{Binding ActiveGameName}" Style="{StaticResource CaptionText}"
                                       Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Games Installed: " Style="{StaticResource CaptionText}"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Text" Value="None detected"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GamesInstalled}" Value="True">
                                                <Setter Property="Text" Value="Yes — monitoring active"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Check Interval: " Style="{StaticResource CaptionText}"/>
                            <TextBlock Style="{StaticResource CaptionText}"
                                       Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold">
                                <Run Text="{Binding CheckIntervalMinutes, Mode=OneWay}"/>
                                <Run Text=" minutes"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="Scan Now" Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,10" Command="{Binding ScanNowCommand}"/>
                        <TextBlock Text="Systema auto-detects game launches and applies boost automatically."
                                   Style="{StaticResource CaptionText}" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Manual Boost Toggle ───────────────────────────────────────── -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Manual Boost" Style="{StaticResource HeadingMedium}"/>
                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Background="#1A00B4FF" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                                <TextBlock Text="MANUAL" FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            Force game mode on without needing an auto-detected game. Useful for games Systema doesn't recognise yet.
                        </TextBlock>
                        <!-- Live status -->
                        <TextBlock Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <Setter Property="Text" Value="Status: OFF  —  No manual boost active"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ManualBoostEnabled}" Value="True">
                                            <Setter Property="Text" Value="Status: ON ✓  —  Manual boost is running, services are paused"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Countdown timer — only shown when manual boost is active -->
                        <TextBlock Margin="0,2,0,4"
                                   Visibility="{Binding ManualBoostEnabled, Converter={StaticResource BoolToVis}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="⏱ Auto-off in: "/>
                            <Run Text="{Binding ManualBoostTimeRemaining}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentYellowBrush}">
                            ⚠ If left on for more than 6 hours, manual boost will auto-disable to restore services.
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Padding="16,9" Command="{Binding ToggleManualBoostCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Content" Value="Enable Manual Boost"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ManualBoostEnabled}" Value="True">
                                        <Setter Property="Content" Value="Disable Manual Boost"/>
                                        <Setter Property="Background" Value="#1AFF4560"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Game Booster Settings ─────────────────────────────────────── -->
            <Border Grid.Row="6" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Booster Settings" Style="{StaticResource HeadingMedium}" Margin="0,0,0,16"/>

                    <!-- Check Interval -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="Game Detection Frequency" Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="How often Systema checks for running game processes. Lower = faster detection, more CPU."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding CheckIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}" Width="60" Margin="0,0,8,0"/>
                            <TextBlock Text="minutes" Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Xbox Override -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="Lock Xbox Services (User Override)" Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0">
                                When enabled, Systema will never automatically disable Xbox services
                                (even when no games are detected).
                            </TextBlock>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding XboxOverride}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Services to Pause — collapsible section -->
                    <Button Command="{Binding ToggleServiceSettingsCommand}"
                            Style="{StaticResource ExpanderButton}" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Services to Pause" Style="{StaticResource BodyText}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Expand to view and edit which services pause during gaming."
                                           Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="▼"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowServiceSettings}" Value="True">
                                                <Setter Property="Text" Value="▲"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <StackPanel Visibility="{Binding ShowServiceSettings, Converter={StaticResource BoolToVis}}"
                                Margin="0,12,0,0">
                    <!-- Kill List Grid -->
                    <TextBlock Text="Services to Pause" Style="{StaticResource BodyText}"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="These services are paused when a game launches and restored when it closes. Remove any that you want to keep running during gaming."
                               Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <!-- Header row -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0"
                            CornerRadius="6,6,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SERVICE" Style="{StaticResource CaptionText}" FontWeight="Bold"/>
                            <TextBlock Text="DESCRIPTION" Style="{StaticResource CaptionText}" FontWeight="Bold" Grid.Column="1"/>
                        </Grid>
                    </Border>

                    <!-- Kill list items -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="0,0,6,6" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding KillListItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                                Padding="10,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ServiceName}" Style="{StaticResource BodyText}"
                                                           FontSize="12" FontFamily="Cascadia Mono, Consolas, monospace"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}"
                                                           Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Grid.Column="2" Content="x" FontSize="14"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{StaticResource AccentRedBrush}"
                                                        Padding="0" Margin="0" Cursor="Hand"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveKillServiceCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Add service via dialog -->
                    <Button Margin="0,8,0,0" Content="Add a Service"
                            Style="{StaticResource GhostButton}" Padding="12,6"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenServicePickerCommand}"/>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Save Settings" Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,0" Command="{Binding SaveSettingsCommand}"/>
                        <Button Content="Reset to Defaults" Style="{StaticResource GhostButton}"
                                Command="{Binding ResetKillListCommand}"/>
                    </StackPanel>
                    </StackPanel><!-- end collapsible service settings -->
                </StackPanel>
            </Border>

            <!-- ── Boost Actions ─────────────────────────────────────────────── -->
            <Border Grid.Row="8" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Boost Actions" Style="{StaticResource HeadingMedium}" Margin="0,0,0,4"/>
                    <TextBlock Text="Extra actions applied when a game launches. All changes are fully restored when the game exits."
                               Style="{StaticResource CaptionText}" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Free memory on boost -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Free memory on game start" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Trims background processes' working sets so the game has more RAM available immediately."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding FreeMemoryOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Suppress notifications -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Suppress notifications" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Silences Windows toast pop-ups while you're gaming. Restored to normal when the game exits."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding SuppressNotifications}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- High Performance power plan -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="High Performance power plan" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Switches to High Performance mode for maximum CPU throughput while gaming. Your previous power plan is restored on exit."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding HighPerfPowerPlan}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 1 ms timer resolution -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="1 ms timer resolution" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Sets Windows scheduler tick to 1 ms (from ~15.6 ms default). Reduces frame-time jitter and input lag. Restored on game exit."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding TimerResolutionOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disable Game Bar & DVR -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Disable Game Bar &amp; DVR" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Turns off background game capture and Xbox Game Bar overlays. Frees GPU encoder bandwidth. Restored on game exit."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding DisableGameBar}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- GPU & multimedia system profile -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="GPU &amp; multimedia system profile" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Raises Windows Multimedia scheduler priority and SystemResponsiveness to 0 so the game gets maximum CPU quanta. Restored on exit."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding GpuProfileOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disable Nagle's algorithm -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Disable Nagle's algorithm" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Sets TcpAckFrequency and TCPNoDelay on all adapters to reduce TCP latency in online games. Restored on game exit."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding DisableNagleOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Flush DNS cache -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Flush DNS cache on game start" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Clears stale DNS entries so the first connection to game servers resolves fresh. (No restore needed — DNS repopulates automatically.)"
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding FlushDnsOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disable NIC power saving -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Disable network adapter power saving" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Prevents Windows from throttling your NIC to save power mid-game. Restored to original setting when the game exits."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding NicPowerSavingOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disable Wi-Fi when Ethernet is connected -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Disable Wi-Fi when ethernet is connected" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Turns off Wi-Fi at game start if a wired ethernet connection is active. Eliminates background wireless scanning that can cause micro-stutters. Wi-Fi is re-enabled automatically when the game exits — only if it was on beforehand."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding DisableWifiOnEthernet}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Disable Bluetooth radio -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Center">
                            <TextBlock Text="Disable Bluetooth while gaming" Style="{StaticResource BodyText}" FontWeight="SemiBold"/>
                            <TextBlock Text="Turns off the Bluetooth radio at game start to reduce wireless interrupt overhead. Bluetooth is automatically re-enabled when the game exits — only if it was on before the game launched. Disable this if you use a Bluetooth controller or headset."
                                       Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding DisableBluetoothOnBoost}" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="Save Boost Actions" Style="{StaticResource PrimaryButton}"
                            Padding="16,8" HorizontalAlignment="Left"
                            Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- ── Detection Info ────────────────────────────────────────────── -->
            <Border Grid.Row="10" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="What Systema Detects" Style="{StaticResource HeadingMedium}" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Border Background="#161B25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Games" Style="{StaticResource CaptionText}" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="Roblox, Fortnite, Minecraft" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="CS2, GTA V, Valorant, LoL" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="Elden Ring, Cyberpunk, more" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161B25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Anti-Cheats" Style="{StaticResource CaptionText}" FontWeight="Bold"
                                           Foreground="{StaticResource AccentYellowBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="Vanguard (vgc)" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="Easy Anti-Cheat" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="BattlEye (BEService)" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#161B25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Launchers &amp; Platforms" Style="{StaticResource CaptionText}" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="Steam, Epic Games" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="Battle.net, Xbox App" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="Riot Client" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <TextBlock Grid.Row="11" Text="{Binding StatusMessage}"
                       Style="{StaticResource CaptionText}" Margin="0,12,0,0"/>
        </Grid>
    </ScrollViewer>
</UserControl>

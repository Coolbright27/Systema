<UserControl x:Class="Systema.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters"
             xmlns:models="clr-namespace:Systema.Models"
             Background="{StaticResource BgPrimaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Transparent, borderless clickable button used for section expanders -->
        <Style x:Key="ExpanderButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="0">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#0CFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Cleanup &amp; Services" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="Stop background data collection and remove software you don't need."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Telemetry Killer -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Data Collection" Style="{StaticResource HeadingMedium}"/>
                            <Border Background="{StaticResource AccentRedBrush}" CornerRadius="4"
                                    Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="ADVANCED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="500">
                            Stops Windows from quietly sending usage statistics and diagnostics to Microsoft in the background.
                            Your internet, Windows Update, and security features are not affected.
                            You can allow collection again at any time.
                        </TextBlock>
                        <TextBlock Margin="0,6,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TelemetryKillerActive}" Value="True">
                                            <Setter Property="Text" Value="Status: OFF — Data collection is stopped"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TelemetryKillerActive}" Value="False">
                                            <Setter Property="Text" Value="Status: ON — Microsoft is collecting data"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Command="{Binding ToggleTelemetryKillerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                    <Setter Property="Content" Value="Stop Data Collection"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TelemetryKillerActive}" Value="True">
                                            <Setter Property="Content" Value="Allow Data Collection"/>
                                            <Setter Property="Background" Value="{StaticResource AccentYellowBrush}"/>
                                            <Setter Property="Foreground" Value="#0D0F14"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Service Stripper -->
            <StackPanel Grid.Row="4">
                <!-- Header row with Disable All Recommended -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Background Services" Style="{StaticResource HeadingMedium}"/>
                        <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="4"
                                Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="MODERATE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Disable Recommended Services"
                            Style="{StaticResource DangerButton}" Padding="14,6"
                            Command="{Binding DisableAllRecommendedCommand}"
                            ToolTip="Disables all services marked RECOMMENDED in one click"/>
                </Grid>

                <!-- Description + Color legend -->
                <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,8" MaxWidth="700">
                    These Windows services run in the background. Disabling ones you don't use frees up memory and can speed up your PC.
                    Services marked RECOMMENDED are safe to disable for most users. You can always re-enable them here.
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentRedBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Disabled — not using resources (optimized)" Style="{StaticResource CaptionText}" Margin="0,0,14,0"/>
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentYellowBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Manual — only starts when needed" Style="{StaticResource CaptionText}" Margin="0,0,14,0"/>
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentGreenBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Running — using memory/CPU" Style="{StaticResource CaptionText}"/>
                </StackPanel>

                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SERVICE" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="STATUS" Style="{StaticResource CaptionText}" Grid.Column="1"/>
                                <TextBlock Text="START TYPE" Style="{StaticResource CaptionText}" Grid.Column="2"/>
                                <TextBlock Text="ACTIONS" Style="{StaticResource CaptionText}" Grid.Column="3" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Services}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,10" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOptimized}" Value="True">
                                                        <Setter Property="Background" Value="#0A1A10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="240"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Style="{StaticResource BodyText}" Margin="0,0,8,0"/>
                                                    <Border CornerRadius="4" Padding="5,1" VerticalAlignment="Center"
                                                            Background="#1A00B4FF" BorderBrush="{StaticResource AccentBlueBrush}"
                                                            BorderThickness="1"
                                                            Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="RECOMMENDED" FontSize="8" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="320">
                                                    <Run Text="{Binding Description}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Tooltip}" Foreground="#FFB800" FontStyle="Italic"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Red}">
                                                                    <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Yellow}">
                                                                    <Setter Property="Fill" Value="{StaticResource AccentYellowBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Green}">
                                                                    <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding StartType}" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Red}">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Yellow}">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Green}">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="Disable" Padding="10,4" Margin="0,0,6,0" FontSize="11"
                                                        Command="{Binding DataContext.DisableServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Red}">
                                                                    <Setter Property="Opacity" Value="0.4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Manual" Padding="10,4" Margin="0,0,6,0" FontSize="11"
                                                        Command="{Binding DataContext.SetManualCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Yellow}">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentYellowBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Enable" Padding="10,4" FontSize="11"
                                                        Command="{Binding DataContext.EnableServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColorState}" Value="{x:Static models:ServiceColorState.Green}">
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Optional Features -->
            <StackPanel Grid.Row="6">
                <!-- Expander header -->
                <Button Command="{Binding ToggleWindowsFeaturesCommand}"
                        Style="{StaticResource ExpanderButton}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Windows Features" Style="{StaticResource HeadingMedium}"/>
                                <!-- Loading indicator for DISM operations -->
                                <TextBlock Margin="16,0,0,0" Style="{StaticResource CaptionText}"
                                           Foreground="{StaticResource AccentYellowBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsFeatureLoading, Converter={StaticResource BoolToVis}}">
                                    DISM running...
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0">
                                Turn built-in Windows features on or off — like Hyper-V or WSL. Expand to view.
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▼"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowWindowsFeatures}" Value="True">
                                            <Setter Property="Text" Value="▲"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <StackPanel Visibility="{Binding ShowWindowsFeatures, Converter={StaticResource BoolToVis}}">
                <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,12">
                    Turn built-in Windows features on or off — like virtual machine support (Hyper-V) or Windows Subsystem for Linux.
                    A restart is required after any change.
                </TextBlock>

                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Column headers -->
                        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FEATURE" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="STATE" Style="{StaticResource CaptionText}" Grid.Column="1"/>
                                <TextBlock Text="ACTION" Style="{StaticResource CaptionText}" Grid.Column="2" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <!-- Feature rows -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding OptionalFeatures}" MaxHeight="500">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Name + description -->
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource BodyText}" FontSize="12"
                                                               Margin="0,0,8,0"/>
                                                    <Border CornerRadius="4" Padding="5,2" VerticalAlignment="Center"
                                                            Background="#1AFF3B00" BorderBrush="{StaticResource AccentRedBrush}"
                                                            BorderThickness="1"
                                                            Visibility="{Binding IsRecommendedToRemove, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="REMOVE RECOMMENDED" FontSize="8" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource CaptionText}"
                                                           TextWrapping="Wrap" MaxWidth="400"
                                                           Margin="0,2,0,0"
                                                           Visibility="{Binding Description, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                            <!-- State -->
                                            <TextBlock Grid.Column="1" Text="{Binding State}" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Button Padding="10,4" FontSize="11"
                                                        Command="{Binding DataContext.DisableOptionalFeatureCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Name}"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                            <Setter Property="Content" Value="Remove"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsFeatureLoading,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Padding="10,4" FontSize="11"
                                                        Command="{Binding DataContext.EnableOptionalFeatureCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Name}"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                            <Setter Property="Content" Value="Enable"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsFeatureLoading,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
                </StackPanel><!-- end collapsible Windows Features -->
            </StackPanel>

            <!-- Status + bottom actions -->
            <Grid Grid.Row="8" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Refresh Services" Style="{StaticResource GhostButton}"
                            Command="{Binding RefreshCommand}"/>
                </Grid>
                <!-- Open Services Control Panel -->
                <Button Grid.Row="2" Content="Open Windows Services Manager"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" Padding="14,6"
                        Command="{Binding OpenServicesMscCommand}"
                        ToolTip="Opens the native Windows Services Control Panel"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="Systema.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters"
             Background="{StaticResource BgPrimaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: header -->
                <RowDefinition Height="20"/>   <!-- 1: spacer -->
                <RowDefinition Height="Auto"/> <!-- 2: Block Preview Updates card -->
                <RowDefinition Height="16"/>   <!-- 3: spacer -->
                <RowDefinition Height="Auto"/> <!-- 4: DNS card -->
                <RowDefinition Height="16"/>   <!-- 5: spacer -->
                <RowDefinition Height="Auto"/> <!-- 6: Core Parking card -->
                <RowDefinition Height="16"/>   <!-- 7: spacer -->
                <RowDefinition Height="Auto"/> <!-- 8: Fast Startup card -->
                <RowDefinition Height="16"/>   <!-- 9: spacer -->
                <RowDefinition Height="Auto"/> <!-- 10: NTFS Last-Access card -->
                <RowDefinition Height="16"/>   <!-- 11: spacer -->
                <RowDefinition Height="Auto"/> <!-- 12: Realtek card -->
                <RowDefinition Height="16"/>   <!-- 13: spacer -->
                <RowDefinition Height="Auto"/> <!-- 14: status bar -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="System Tweaks" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Text="Safe, reversible tweaks to fine-tune your PC."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ===== CARD: Block Windows Preview Updates ===== -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>

                    <!-- Header row with toggle -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Block Preview Updates"
                                           Style="{StaticResource HeadingMedium}"/>
                                <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="4"
                                        Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="SAFE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="600">
                                Stops Windows Update from offering unstable preview (Insider) builds.
                                Regular security and feature updates still install as normal.
                            </TextBlock>
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding BlockPreviewUpdates, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Status indicator -->
                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                <Setter Property="Text" Value="Status: OFF  —  Preview updates are allowed"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BlockPreviewUpdates}" Value="True">
                                        <Setter Property="Text" Value="Status: ON ✓  —  Preview updates are blocked"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding IsPreviewUpdatesLoading, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Applying..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ===== CARD: DNS Switcher ===== -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="DNS Switcher" Style="{StaticResource HeadingMedium}"/>
                        <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="4"
                                Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="SAFE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,12"
                               MaxWidth="640">
                        Choose faster, more private DNS servers for your internet connection.
                        Cloudflare (1.1.1.1) is the recommended choice for most users — it's fast and doesn't track you.
                        Click "Reset to DHCP" to go back to your internet provider's default.
                    </TextBlock>

                    <!-- Current DNS display -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Current DNS: " Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="{Binding CurrentDns}" Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Profile picker + buttons -->
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding DnsProfiles}"
                                  SelectedItem="{Binding SelectedDnsProfile}"
                                  DisplayMemberPath="Name"
                                  Width="240"
                                  Margin="0,0,10,0"
                                  VerticalAlignment="Center"/>
                        <Button Content="Apply DNS" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyDnsCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="Reset to DHCP" Style="{StaticResource GhostButton}"
                                Command="{Binding ResetDnsCommand}"/>
                    </StackPanel>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsDnsLoading, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Applying..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== CARD: Core Parking ===== -->
            <Border Grid.Row="6" Style="{StaticResource Card}">
                <StackPanel>

                    <!-- Header row with toggle -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="CPU Core Efficiency"
                                           Style="{StaticResource HeadingMedium}"/>
                                <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="4"
                                        Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="MODERATE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                                </Border>
                                <Border CornerRadius="4" Padding="5,2" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Background="#1A00E5A0" BorderBrush="{StaticResource AccentGreenBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="RECOMMENDED" FontSize="8" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreenBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="600">
                                Keeps Windows' idle core management on, so CPU cores automatically power down when not needed.
                                Reduces heat and lets busy cores run faster.
                                A startup task is created so the setting survives restarts.
                            </TextBlock>
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding CoreParkingEnforced, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Status indicator -->
                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                <Setter Property="Text" Value="Status: OFF  —  Core efficiency is not enforced"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CoreParkingEnforced}" Value="True">
                                        <Setter Property="Text" Value="Status: ON ✓  —  Core efficiency is active and persists on restart"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding IsCoreParkingLoading, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Working..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ===== CARD: Disable Fast Startup ===== -->
            <Border Grid.Row="8" Style="{StaticResource Card}">
                <StackPanel>

                    <!-- Header row with toggle -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Disable Fast Startup"
                                           Style="{StaticResource HeadingMedium}"/>
                                <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="4"
                                        Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="MODERATE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="600">
                                Windows Fast Startup saves a kernel snapshot on shutdown to speed up the next boot.
                                Disabling it forces a full clean shutdown each time, preventing driver state corruption,
                                ensuring firmware updates apply correctly, and fixing shutdown/reboot issues on some PCs.
                            </TextBlock>
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding FastStartupDisabled, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Status indicator -->
                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                <Setter Property="Text" Value="Status: OFF  —  Fast Startup is enabled (Windows default)"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FastStartupDisabled}" Value="True">
                                        <Setter Property="Text" Value="Status: ON ✓  —  Fast Startup is disabled (full clean shutdown)"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding IsFastStartupLoading, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Applying..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ===== CARD: Disable NTFS Last-Access Timestamps ===== -->
            <Border Grid.Row="10" Style="{StaticResource Card}">
                <StackPanel>

                    <!-- Header row with toggle -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Disable NTFS Last-Access Timestamps"
                                           Style="{StaticResource HeadingMedium}"/>
                                <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="4"
                                        Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="SAFE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxWidth="600">
                                NTFS normally updates the "Date Accessed" timestamp on every file read, causing
                                unnecessary disk writes on every open. Disabling this reduces background disk
                                activity, lowers SSD write amplification, and can improve responsiveness on
                                systems with many small files (e.g. development machines).
                            </TextBlock>
                        </StackPanel>

                        <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding NtfsLastAccessDisabled, Mode=TwoWay}"/>
                    </Grid>

                    <!-- Status indicator -->
                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                <Setter Property="Text" Value="Status: OFF  —  Last-access timestamps are written on every read (default)"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NtfsLastAccessDisabled}" Value="True">
                                        <Setter Property="Text" Value="Status: ON ✓  —  Last-access timestamp writes are disabled"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding IsNtfsLastAccessLoading, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Applying..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ===== CARD: Remove Realtek Bloat ===== -->
            <Border Grid.Row="12" Style="{StaticResource Card}"
                    Visibility="{Binding HasRealtekHardware, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Realtek App Cleanup" Style="{StaticResource HeadingMedium}"/>
                        <Border Background="{StaticResource AccentYellowBrush}" CornerRadius="4"
                                Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="MODERATE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,0,0,12"
                               MaxWidth="640">
                        Removes the Realtek Audio Manager companion app. Your speakers, microphone, and headphones keep working — only the unnecessary app is removed.
                    </TextBlock>

                    <!-- Entry list -->
                    <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,10"
                            MinHeight="56">
                        <!-- Pre-scan placeholder -->
                        <TextBlock Style="{StaticResource CaptionText}"
                                   Text="Click Scan to check for Realtek bloatware on this PC."
                                   VerticalAlignment="Center"
                                   Visibility="{Binding RealtekScanned,
                                       Converter={StaticResource BoolToVis},
                                       ConverterParameter=Invert}"/>
                    </Border>

                    <!-- Post-scan: show item list or empty message -->
                    <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="6"
                            Padding="12,8" Margin="0,-10,0,10"
                            Visibility="{Binding RealtekScanned, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}"
                                       Text="No Realtek bloatware found — your system is clean."
                                       Visibility="{Binding HasRealtekEntries,
                                           Converter={StaticResource BoolToVis},
                                           ConverterParameter=Invert}"/>
                            <ItemsControl ItemsSource="{Binding RealtekEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       Style="{StaticResource BodyText}" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Version}"
                                                       Style="{StaticResource CaptionText}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Actions row -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Scan" Style="{StaticResource GhostButton}"
                                Command="{Binding ScanRealtekCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="Remove Realtek App" Style="{StaticResource DangerButton}"
                                Command="{Binding RemoveRealtekCommand}"
                                IsEnabled="{Binding RealtekScanned}"/>
                    </StackPanel>

                    <!-- Loading indicator -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRealtekLoading, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Style="{StaticResource AccentProgressBar}" Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="Working..." Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Text="{Binding RealtekStatusMessage}"
                               Style="{StaticResource CaptionText}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ===== STATUS BAR ===== -->
            <Grid Grid.Row="14" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>

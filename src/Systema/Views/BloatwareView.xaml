<UserControl x:Class="Systema.Views.BloatwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters"
             Background="{StaticResource BgPrimaryBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: header -->
                <RowDefinition Height="20"/>    <!-- 1: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 2: info card -->
                <RowDefinition Height="16"/>    <!-- 3: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 4: scanning indicator -->
                <RowDefinition Height="Auto"/>  <!-- 5: app list card -->
                <RowDefinition Height="16"/>    <!-- 6: spacer -->
                <RowDefinition Height="Auto"/>  <!-- 7: status -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="App Cleanup" Style="{StaticResource HeadingLarge}"/>
                <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap">
                    Remove pre-installed Microsoft apps you don't use. Your PC stays healthy and
                    nothing breaks — only extras are removed. You can reinstall any of them from the
                    Microsoft Store if you change your mind.
                </TextBlock>
            </StackPanel>

            <!-- ===== INFO CARD ===== -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Safe Pre-installed App List" Style="{StaticResource HeadingMedium}"/>
                            <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="4"
                                    Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="SAFE" FontSize="9" FontWeight="Bold" Foreground="#0D0F14"/>
                            </Border>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            Every app on this list has been verified safe to remove. None of them are
                            required for Windows, the Microsoft Store, Xbox, or other core functions.
                            A safety restore point is created before anything is removed.
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🔍  Scan Again"
                            Style="{StaticResource GhostButton}" Padding="16,9"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding IsNotLoading}"
                            Command="{Binding RescanCommand}"/>
                </Grid>
            </Border>

            <!-- ===== LOADING SPINNER ===== -->
            <Border Grid.Row="4" Style="{StaticResource Card}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Style="{StaticResource AccentProgressBar}" Margin="0,0,16,0"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="Scanning for pre-installed apps…" Style="{StaticResource BodyText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ===== APP LIST CARD (visible after scan) ===== -->
            <Border Grid.Row="5" Style="{StaticResource Card}" Padding="0"
                    Visibility="{Binding HasScannedOnce, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- Card header: summary + select-all buttons -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="20,12" CornerRadius="10,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ScanSummary}"
                                       Style="{StaticResource BodyText}" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding HasApps, Converter={StaticResource BoolToVis}}">
                                <Button Content="Select All" Style="{StaticResource GhostButton}"
                                        Padding="12,6" Margin="0,0,8,0"
                                        Command="{Binding SelectAllCommand}"/>
                                <Button Content="Deselect All" Style="{StaticResource GhostButton}"
                                        Padding="12,6"
                                        Command="{Binding DeselectAllCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Empty state — no removable apps found -->
                    <Border Padding="20,28"
                            Visibility="{Binding HasApps, Converter={StaticResource BoolToVis},
                                         ConverterParameter=Invert}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="✓" FontSize="36" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="No removable pre-installed apps found — your system looks clean."
                                       Style="{StaticResource BodyText}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- App rows -->
                    <ItemsControl ItemsSource="{Binding Apps}"
                                  Visibility="{Binding HasApps, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="20,12" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>  <!-- checkbox -->
                                            <ColumnDefinition Width="*"/>     <!-- name + desc -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                                  Margin="0,0,16,0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Command="{Binding DataContext.SelectionChangedCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource BodyText}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Style="{StaticResource CaptionText}"
                                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Footer: remove button + removal progress -->
                    <Border Padding="20,14"
                            Visibility="{Binding HasApps, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Removal progress (visible while removing) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding IsRemoving, Converter={StaticResource BoolToVis}}">
                                <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                             Style="{StaticResource AccentProgressBar}" Margin="0,0,12,0"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Remove button -->
                            <Button Grid.Column="1"
                                    Style="{StaticResource DangerButton}" Padding="20,10"
                                    Command="{Binding RemoveSelectedCommand}"
                                    IsEnabled="{Binding IsNotRemoving}">
                                <TextBlock>
                                    <Run Text="🗑  Remove Selected ("/>
                                    <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                            </Button>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ===== STATUS (non-removing) ===== -->
            <TextBlock Grid.Row="7" Text="{Binding StatusMessage}" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRemoving}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </Grid>
    </ScrollViewer>
</UserControl>

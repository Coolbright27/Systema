<Application x:Class="Systema.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Systema.Core.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <conv:BoolToVisibilityConverter x:Key="GlobalBoolToVis"/>
            <conv:SafetyLevelToColorConverter x:Key="GlobalSafetyColor"/>
            <conv:SafetyLevelToBadgeConverter x:Key="GlobalSafetyBadge"/>
            <conv:EqualityConverter x:Key="GlobalEquality"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
